[run]
branch = True
relative_files = True
source =
    src
omit =
    */__pycache__/*
    */tests/*
    */test_*.py
    */api/*
    */htmlcov/*
    */.venv/*

[report]
omit =
    */__pycache__/*
    */tests/*
    */test_*.py
    */api/*
    */htmlcov/*
    */.venv/*
show_missing = True
skip_empty = True

[html]
directory = htmlcov